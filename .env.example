# Authentication Codes
VITE_ADMIN_CODE=your_admin_code_here
VITE_TEACHER_CODE=your_teacher_code_here

# Database Configuration
DATABASE_URL=mysql://user:password@host:port/database

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# OAuth Configuration (if using external OAuth)
OAUTH_SERVER_URL=https://your-oauth-server.com
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.com
VITE_APP_ID=your_app_id_here

# API Configuration
BUILT_IN_FORGE_API_URL=https://your-api-url.com
BUILT_IN_FORGE_API_KEY=your_api_key_here
VITE_FRONTEND_FORGE_API_KEY=your_frontend_api_key_here
VITE_FRONTEND_FORGE_API_URL=https://your-frontend-api-url.com

# App Configuration
VITE_APP_TITLE=مسارات - ابتدائية أبها الأهلية
VITE_APP_LOGO=/logo.png

# Analytics (optional)
VITE_ANALYTICS_ENDPOINT=https://your-analytics-endpoint.com
VITE_ANALYTICS_WEBSITE_ID=your_website_id_here

# Owner Information
OWNER_OPEN_ID=owner_id_here
OWNER_NAME=Owner Name
